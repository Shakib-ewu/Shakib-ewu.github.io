rained","placeholder":{"fallback":"data:image/png;base64,"},"images":{"fallback":{"src":"/static/c85999431093c6bfb7ca66abc0c3f546/3e1ab/SRMS.png","srcSet":"/static/c85999431093c6bfb7ca66abc0c3f546/57a76/SRMS.png 175w,\n/static/c85999431093c6bfb7ca66abc0c3f546/f00e6/SRMS.png 350w,\n/static/c85999431093c6bfb7ca66abc0c3f546/3e1ab/SRMS.png 700w,\n/static/c85999431093c6bfb7ca66abc0c3f546/35a97/SRMS.png 1400w","sizes":"(min-width: 700px) 700px, 100vw"},"sources":[{"srcSet":"/static/c85999431093c6bfb7ca66abc0c3f546/50167/SRMS.avif 175w,\n/static/c85999431093c6bfb7ca66abc0c3f546/5a8a9/SRMS.avif 350w,\n/static/c85999431093c6bfb7ca66abc0c3f546/bc4f6/SRMS.avif 700w,\n/static/c85999431093c6bfb7ca66abc0c3f546/44296/SRMS.avif 1400w","type":"image/avif","sizes":"(min-width: 700px) 700px, 100vw"},{"srcSet":"/static/c85999431093c6bfb7ca66abc0c3f546/81b0f/SRMS.webp 175w,\n/static/c85999431093c6bfb7ca66abc0c3f546/bfc62/SRMS.webp 350w,\n/static/c85999431093c6bfb7ca66abc0c3f546/74bac/SRMS.webp 700w,\n/static/c85999431093c6bfb7ca66abc0c3f546/67855/SRMS.webp 1400w","type":"image/webp","sizes":"(min-width: 700px) 700px, 100vw"}]},"width":700,"height":467}}},"tech":["JavaScript","PHP","HTML","CSS"],"github":"https://github.com/Shakib-ewu/Student-Result-Management-System","external":null,"cta":null},"html":"<p>A streamlined web application for managing and tracking student academic performance on a semester-by-semester basis. It enables educators to record grades based on specific courses taken by each student and allows students to view their transcript, calculate GPAs, and monitor their academic progress throughout their university journey.</p>"}},{"node":{"frontmatter":{"title":"Rubino Cypress","cover":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","placeholder":{"fallback":"data:image/png;base64,"},"images":{"fallback":{"src":"/static/ee320df3a5f7bbef3cfc3e3b8b28bd68/3e1ab/rubino.png","srcSet":"/static/ee320df3a5f7bbef3cfc3e3b8b28bd68/57a76/rubino.png 175w,\n/static/ee320d